# Nginx reverse proxy for Momentum game server (Colyseus over WebSocket).
# Save as /etc/nginx/sites-available/momentum-game on the VPS,
# replace `game.tondomaine.fr` with your real domain, then:
#   ln -s /etc/nginx/sites-available/momentum-game /etc/nginx/sites-enabled/
#   nginx -t && systemctl reload nginx
#   certbot --nginx -d game.tondomaine.fr

# Redirect HTTP to HTTPS
server {
    listen 80;
    server_name game.tondomaine.fr;
    return 301 https://$host$request_uri;
}

# Main HTTPS server with WebSocket upgrade
server {
    listen 443 ssl http2;
    server_name game.tondomaine.fr;

    # SSL certificates (filled in by certbot)
    ssl_certificate /etc/letsencrypt/live/game.tondomaine.fr/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/game.tondomaine.fr/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    # Security headers
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Limits — Colyseus messages are small, but be generous for occasional bursts
    client_max_body_size 1m;

    # Reverse proxy to Colyseus on localhost
    location / {
        proxy_pass http://127.0.0.1:2567;
        proxy_http_version 1.1;

        # WebSocket upgrade
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # Forward client info
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Long-lived connections
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;

        # Disable buffering for live game traffic
        proxy_buffering off;
    }
}
